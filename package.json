{
  "name": "vanta-engine",
  "version": "1.1.16",
  "description": "A node based 3D and 2D engine compatible with web environments.",
  "type": "module",
  "repository": {
    "url": "git+https://github.com/FrewtyPebbles/Vanta-3D-Engine.git"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "browser": {
    "module": false,
    "fs": false,
    "path": false,
    "url": false
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx build_scripts/sync_shaders.mts && tsup",
    "prepublishOnly": "npm run build",
    "build:watch": "ts-node build_scripts/sync_shaders.mts && tsup --watch",
    "clean": "rimraf dist"
  },
  "keywords": [
    "game",
    "engine",
    "render",
    "rendering",
    "3d",
    "webgl2",
    "webgl"
  ],
  "author": "William Lim",
  "devDependencies": {
    "@types/node": "^25.2.3",
    "glob": "^13.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@vicimpa/glm": "^0.1.10"
  },
  "dependencies": {
    "wasmoon": "^1.16.0"
  }
}
